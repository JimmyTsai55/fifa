OPENAI_API_KEY=sk-...
APIFOOTBALL_KEY=...
TAVILY_KEY=tvly-...
# 多把 X-API-Key（逗號分隔），用於 /ask 端點的應用層認證
WC_API_KEYS=changeme1,changeme2
# 選用：賽季。預設 2022（免費方案僅 2022–2024）。升級付費後可設 2026。
WC_SEASON=2022
OPENAI_DEFAULT_MODEL=gpt-4o-mini
# uvicorn 監聽埠，與 Dockerfile/Cloud Run --port 一致
PORT=8887
# 儲存後端：目前僅支援 sqlite
STORAGE_BACKEND=sqlite
